{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/(frontend)/layout,_N_T_/(frontend)/van-hoa/layout,_N_T_/(frontend)/van-hoa/page,_N_T_/van-hoa"},"segmentPaths":["/_tree","/_full","/!KGZyb250ZW5kKQ/van-hoa/__PAGE__","/!KGZyb250ZW5kKQ/van-hoa","/!KGZyb250ZW5kKQ","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"vi\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/images/byd-logo.png\" as=\"image\"/><link rel=\"preload\" as=\"image\" href=\"/images/hoat-dong-20-10.webp\" fetchPriority=\"high\"/><link rel=\"stylesheet\" href=\"/_next/static/css/09844bcc633d00b4.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-09d2e605a48d46b3.js\"/><script src=\"/_next/static/chunks/4bd1b696-e356ca5ba0218e27.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-3fb4e6ee851037bb.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-3f2f4db84a984ed8.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-f62a38ff68ab7f42.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(frontend)/layout-9ab678a6f57c31ca.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(frontend)/page-565c14a641d599b4.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(frontend)/van-hoa/page-f2be34d0faf19345.js\" async=\"\"></script><title>BYD Việt Nam - Build Your Dream</title><meta name=\"description\" content=\"Kiến tạo tương lai thương mại điện tử đột phá. Công ty TNHH BYD Việt Nam.\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex flex-col bg-white\"><div class=\"bg-[#EC1313] text-white text-xs hidden md:block relative z-50\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-9\"><div class=\"flex items-center gap-6\"><a href=\"mailto:hcns.byd@gmail.com\" class=\"flex items-center gap-1.5 hover:text-red-100 transition-colors\"><svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\"></path></svg>hcns.byd@gmail.com</a><a href=\"tel:+84281234567\" class=\"flex items-center gap-1.5 hover:text-red-100 transition-colors\"><svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z\"></path></svg>0969 240 885</a></div><div class=\"flex items-center gap-4\"><a href=\"https://www.facebook.com/profile.php?id=61557780033666\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebook BYD\" class=\"hover:text-red-100 transition-colors\"><svg class=\"w-4 h-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z\"></path></svg></a><a href=\"https://vt.tiktok.com/ZSuA5QF45/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"TikTok BYD\" class=\"hover:text-red-100 transition-colors\"><svg class=\"w-4 h-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z\"></path></svg></a></div></div></div><header class=\"sticky top-0 z-40 transition-all duration-300 bg-white border-b border-slate-100\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex items-center justify-between h-18 lg:h-20\"><a aria-label=\"Trang chủ BYD\" class=\"flex items-center gap-3 shrink-0\" href=\"/\"><img src=\"/images/byd-logo.png\" alt=\"BYD Logo\" class=\"h-10 lg:h-12 w-auto\" loading=\"eager\" decoding=\"async\" width=\"160\" height=\"48\"/></a><nav class=\"hidden md:flex items-center gap-1\"><a class=\"px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-[#475569] hover:text-[#0F172A] hover:bg-slate-50\" href=\"/\">Trang chủ</a><a class=\"px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-[#475569] hover:text-[#0F172A] hover:bg-slate-50\" href=\"/gioi-thieu\">Giới thiệu</a><a class=\"px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-[#475569] hover:text-[#0F172A] hover:bg-slate-50\" href=\"/linh-vuc\">Lĩnh vực</a><a class=\"px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-[#EC1313] bg-[rgba(236,19,19,0.06)]\" href=\"/van-hoa\">Văn hóa</a><a class=\"px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-[#475569] hover:text-[#0F172A] hover:bg-slate-50\" href=\"/tuyen-dung\">Tuyển dụng</a><a class=\"px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-[#475569] hover:text-[#0F172A] hover:bg-slate-50\" href=\"/tin-tuc\">Tin tức</a></nav><div class=\"hidden md:flex items-center gap-3\"><button type=\"button\" aria-label=\"Tìm kiếm\" class=\"p-2.5 rounded-lg text-[#475569] hover:bg-slate-50 transition-colors\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path></svg></button><button type=\"button\" class=\"bg-[#EC1313] text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-[#d41111] transition-all hover:shadow-lg hover:shadow-red-200 duration-300\">Ứng tuyển ngay</button></div><button type=\"button\" aria-label=\"Mở menu điều hướng\" aria-expanded=\"false\" aria-controls=\"mobile-navigation\" class=\"md:hidden p-2 rounded-lg text-[#475569] hover:bg-slate-100\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></div></header><main class=\"flex-1\"><div class=\"bg-white\"><section class=\"relative min-h-[500px] lg:min-h-[600px] flex items-center overflow-hidden\"><div class=\"absolute inset-0\"><img src=\"/images/hoat-dong-20-10.webp\" alt=\"Văn hóa BYD\" class=\"w-full h-full object-cover\" loading=\"eager\" fetchPriority=\"high\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-r from-[#0F172A]/90 via-[#0F172A]/70 to-[#0F172A]/30\"></div></div><div class=\"absolute top-20 right-20 w-72 h-72 bg-[#EC1313]/10 rounded-full blur-3xl pointer-events-none\"></div><div class=\"absolute bottom-10 left-10 w-56 h-56 bg-[#EC1313]/5 rounded-full blur-2xl pointer-events-none\"></div><div class=\"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full\"><div class=\"max-w-2xl\"><div class=\"inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-5 py-2.5 rounded-full mb-8 border border-white/20\"><div class=\"w-2.5 h-2.5 rounded-full bg-[#EC1313] animate-pulse\"></div><span class=\"text-white/90 text-sm font-semibold tracking-wider uppercase\">Văn hóa doanh nghiệp</span></div><h1 class=\"text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[1.05] mb-6 tracking-tight\">Văn hóa<!-- --> <span class=\"text-[#EC1313]\">BYD</span></h1><p class=\"text-lg lg:text-xl text-white/80 leading-relaxed mb-10 max-w-xl\">Nơi mỗi cá nhân được tôn trọng, phát triển và cùng nhau kiến tạo những giá trị bền vững cho cộng đồng.</p><div class=\"flex flex-wrap gap-4\"><button type=\"button\" class=\"group bg-[#EC1313] text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-[#d41111] transition-all duration-300 hover:shadow-2xl hover:shadow-red-500/30 flex items-center gap-3\">Gia nhập ngay<svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg></button><button type=\"button\" class=\"border-2 border-white/40 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/10 hover:border-white/60 transition-all duration-300 backdrop-blur-sm\">Về BYD</button></div></div></div><div class=\"absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-white to-transparent\"></div></section><section class=\"py-20 lg:py-28 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><div class=\"w-1.5 h-1.5 rounded-full bg-[#EC1313]\"></div><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Giá trị văn hóa</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-tight\">NHỮNG GIÁ TRỊ CHÚNG TÔI THEO ĐUỔI</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">BYD xây dựng văn hóa doanh nghiệp dựa trên nền tảng con người, sáng tạo và trách nhiệm cộng đồng.</p></div><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-20\"><div><h3 class=\"text-2xl lg:text-3xl font-bold text-[#0F172A] mb-6\">Nghĩ Lớn — Tốc Độ — WOW</h3><p class=\"text-[#475569] text-lg leading-relaxed mb-6\">Tại BYD, mỗi nhân viên đều là một cá nhân độc đáo với tiềm năng riêng. Chúng tôi tạo môi trường để mỗi người có thể phát huy tối đa khả năng của mình, đóng góp vào sự phát triển chung của tổ chức.</p><p class=\"text-[#475569] leading-relaxed\">Chính sách nhân sự linh hoạt, chương trình mentoring 1-1, và văn hóa feedback mở giúp mọi thành viên luôn cảm thấy được lắng nghe và trân trọng.</p></div><div class=\"rounded-2xl overflow-hidden shadow-2xl\"><img src=\"/images/du-lich-cua-lo.webp\" alt=\"Văn phòng BYD\" class=\"w-full h-auto object-cover\" loading=\"lazy\" decoding=\"async\"/></div></div><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center\"><div class=\"order-2 lg:order-1 rounded-2xl overflow-hidden shadow-2xl\"><img src=\"/images/sinh-nhat-van-phong.webp\" alt=\"Đội ngũ BYD\" class=\"w-full h-auto object-cover\" loading=\"lazy\" decoding=\"async\"/></div><div class=\"order-1 lg:order-2\"><h3 class=\"text-2xl lg:text-3xl font-bold text-[#0F172A] mb-6\">Tử Tế — Đoàn Kết — Vượt Đích</h3><p class=\"text-[#475569] text-lg leading-relaxed mb-6\">Sáng tạo là DNA của BYD. Chúng tôi khuyến khích mọi ý tưởng mới và tạo không gian an toàn để thử nghiệm. Thất bại được xem là bài học quý giá trên hành trình đổi mới.</p><p class=\"text-[#475569] leading-relaxed\">Hackathon nội bộ hàng quý, Innovation Lab, và chương trình Intrapreneurship giúp nhân viên biến ý tưởng thành sản phẩm thực tế có tác động lớn.</p></div></div></div></section><section class=\"py-20 lg:py-28 bg-[#FAFAFA]\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Quyền lợi</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-tight\">PHÚC LỢI VƯỢT TRỘI</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">BYD cam kết mang đến chế độ đãi ngộ tốt nhất để nhân viên yên tâm cống hiến và phát triển sự nghiệp.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\"><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">💰</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">LƯƠNG THƯỞNG CẠNH TRANH</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Chế độ lương thưởng hấp dẫn, review lương 2 lần/năm theo năng lực thực tế.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">🏥</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">BẢO HIỂM SỨC KHỎE</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Bảo hiểm sức khỏe toàn diện cho nhân viên và người thân, khám sức khỏe định kỳ.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">📚</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">ĐÀO TẠO &amp; PHÁT TRIỂN</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Ngân sách đào tạo cá nhân, cơ hội tham gia hội thảo và chương trình mentoring.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">🏖️</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">NGHỈ PHÉP LINH HOẠT</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">15+ ngày phép/năm, nghỉ phép không giới hạn cho nhân sự cấp Senior trở lên.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">🏠</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">LÀM VIỆC LINH HOẠT</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Hybrid working, tự chọn giờ làm phù hợp, hỗ trợ thiết bị làm việc tại nhà.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">🎯</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">THƯỞNG HIỆU SUẤT</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Bonus quý/năm theo kết quả kinh doanh, thưởng dự án và cổ phiếu ưu đãi.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">🎉</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">HOẠT ĐỘNG GẮN KẾT</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Team building hàng quý, du lịch công ty, tiệc sinh nhật và sự kiện nội bộ.</p></div><div class=\"group bg-white rounded-2xl p-6 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300 hover:-translate-y-1\"><div class=\"text-4xl mb-4\">🚀</div><h3 class=\"text-lg font-bold text-[#0F172A] mb-2 group-hover:text-[#EC1313] transition-colors\">LỘ TRÌNH THĂNG TIẾN</h3><p class=\"text-[#64748B] text-sm leading-relaxed\">Career path rõ ràng, cơ hội thăng tiến nhanh dựa trên năng lực và đóng góp.</p></div></div></div></section><section class=\"py-20 lg:py-28 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Chương trình nổi bật</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-tight\">CHƯƠNG TRÌNH VĂN HÓA</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">Những chương trình đặc biệt giúp BYD trở thành nơi làm việc tuyệt vời nhất.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"group bg-[#FAFAFA] rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300\"><div class=\"flex items-start gap-5\"><div class=\"text-4xl flex-shrink-0\">🎓</div><div><h3 class=\"text-xl font-bold text-[#0F172A] mb-3 group-hover:text-[#EC1313] transition-colors\">BYD ACADEMY</h3><p class=\"text-[#475569] leading-relaxed\">Chương trình đào tạo nội bộ với 100+ khóa học từ kỹ năng cứng đến mềm, do chuyên gia trong và ngoài công ty giảng dạy.</p></div></div></div><div class=\"group bg-[#FAFAFA] rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300\"><div class=\"flex items-start gap-5\"><div class=\"text-4xl flex-shrink-0\">💡</div><div><h3 class=\"text-xl font-bold text-[#0F172A] mb-3 group-hover:text-[#EC1313] transition-colors\">INNOVATION LAB</h3><p class=\"text-[#475569] leading-relaxed\">Không gian sáng tạo mở, nơi nhân viên tự do thử nghiệm ý tưởng mới. Các dự án xuất sắc được đầu tư phát triển thành sản phẩm thực.</p></div></div></div><div class=\"group bg-[#FAFAFA] rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300\"><div class=\"flex items-start gap-5\"><div class=\"text-4xl flex-shrink-0\">❤️</div><div><h3 class=\"text-xl font-bold text-[#0F172A] mb-3 group-hover:text-[#EC1313] transition-colors\">BYD CARES</h3><p class=\"text-[#475569] leading-relaxed\">Chương trình CSR với các hoạt động thiện nguyện, bảo vệ môi trường và hỗ trợ cộng đồng xung quanh.</p></div></div></div><div class=\"group bg-[#FAFAFA] rounded-2xl p-8 border border-slate-100 hover:shadow-xl hover:border-[#EC1313]/20 transition-all duration-300\"><div class=\"flex items-start gap-5\"><div class=\"text-4xl flex-shrink-0\">🧘</div><div><h3 class=\"text-xl font-bold text-[#0F172A] mb-3 group-hover:text-[#EC1313] transition-colors\">WELLNESS PROGRAM</h3><p class=\"text-[#475569] leading-relaxed\">Chương trình chăm sóc sức khỏe toàn diện: yoga, gym, tư vấn tâm lý, và các hoạt động thể thao đội nhóm.</p></div></div></div></div></div></section><section class=\"py-20 lg:py-28 bg-[#FAFAFA]\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><div class=\"w-1.5 h-1.5 rounded-full bg-[#EC1313]\"></div><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Hoạt động nổi bật</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-tight\">KHOẢNH KHẮC BYD</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">Những khoảnh khắc đáng nhớ từ các hoạt động gắn kết, vinh danh và sự kiện nội bộ tại BYD.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\"><button type=\"button\" class=\"group relative overflow-hidden rounded-2xl cursor-pointer lg:col-span-1 md:col-span-1 aspect-[4/3] lg:row-span-2 lg:aspect-auto lg:min-h-[500px] text-left\" aria-label=\"Xem ảnh: HAPPY BIRTHDAY – NHÂN SỰ QUÝ I\"><img src=\"/images/sinh-nhat-quy4.webp\" alt=\"HAPPY BIRTHDAY – NHÂN SỰ QUÝ I\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300\"></div><div class=\"absolute inset-0 flex flex-col justify-end p-5 lg:p-6\"><div class=\"flex items-center gap-2 mb-2\"><span class=\"inline-block bg-[#EC1313] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider\">🎂 Sinh nhật</span><span class=\"text-white/60 text-xs\">Quý I/2025</span></div><h3 class=\"text-white font-bold text-sm lg:text-base leading-snug mb-1 group-hover:text-[#EC1313] transition-colors line-clamp-2\">HAPPY BIRTHDAY – NHÂN SỰ QUÝ I</h3><p class=\"text-white/70 text-xs lg:text-sm leading-relaxed line-clamp-2 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300\">Công ty trân trọng gửi lời chúc mừng sinh nhật tới các thành viên có ngày sinh trong quý. Tuổi mới, chúc mọi người luôn dồi dào sức khỏe!</p></div></button><button type=\"button\" class=\"group relative overflow-hidden rounded-2xl cursor-pointer lg:col-span-1 md:col-span-1 aspect-[4/3]  text-left\" aria-label=\"Xem ảnh: 8/3 – NGÀY CỦA HỘI CHỊ EM\"><img src=\"/images/hoat-dong-20-10.webp\" alt=\"8/3 – NGÀY CỦA HỘI CHỊ EM\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300\"></div><div class=\"absolute inset-0 flex flex-col justify-end p-5 lg:p-6\"><div class=\"flex items-center gap-2 mb-2\"><span class=\"inline-block bg-[#EC1313] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider\">🌸 Sự kiện</span><span class=\"text-white/60 text-xs\">08/03/2025</span></div><h3 class=\"text-white font-bold text-sm lg:text-base leading-snug mb-1 group-hover:text-[#EC1313] transition-colors line-clamp-2\">8/3 – NGÀY CỦA HỘI CHỊ EM</h3><p class=\"text-white/70 text-xs lg:text-sm leading-relaxed line-clamp-2 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300\">Nhân ngày Quốc tế Phụ nữ, BYD gửi lời chúc toàn thể chị em luôn xinh đẹp, ví luôn đầy và mood luôn chill!</p></div></button><button type=\"button\" class=\"group relative overflow-hidden rounded-2xl cursor-pointer aspect-[4/3]  text-left\" aria-label=\"Xem ảnh: TEAM BUILDING – CỬA LÒ 2025\"><img src=\"/images/du-lich-cua-lo.webp\" alt=\"TEAM BUILDING – CỬA LÒ 2025\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300\"></div><div class=\"absolute inset-0 flex flex-col justify-end p-5 lg:p-6\"><div class=\"flex items-center gap-2 mb-2\"><span class=\"inline-block bg-[#EC1313] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider\">✈️ Du lịch</span><span class=\"text-white/60 text-xs\">2025</span></div><h3 class=\"text-white font-bold text-sm lg:text-base leading-snug mb-1 group-hover:text-[#EC1313] transition-colors line-clamp-2\">TEAM BUILDING – CỬA LÒ 2025</h3><p class=\"text-white/70 text-xs lg:text-sm leading-relaxed line-clamp-2 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300\">Chuyến du lịch gắn kết đội ngũ tại Cửa Lò, nơi anh em cùng nhau tận hưởng những khoảnh khắc đáng nhớ.</p></div></button><button type=\"button\" class=\"group relative overflow-hidden rounded-2xl cursor-pointer aspect-[4/3]  text-left\" aria-label=\"Xem ảnh: CẦU LÔNG – GIẢI TỎA NĂNG LƯỢNG\"><img src=\"/images/sinh-nhat-van-phong.webp\" alt=\"CẦU LÔNG – GIẢI TỎA NĂNG LƯỢNG\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300\"></div><div class=\"absolute inset-0 flex flex-col justify-end p-5 lg:p-6\"><div class=\"flex items-center gap-2 mb-2\"><span class=\"inline-block bg-[#EC1313] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider\">🏸 Thể thao</span><span class=\"text-white/60 text-xs\">2025</span></div><h3 class=\"text-white font-bold text-sm lg:text-base leading-snug mb-1 group-hover:text-[#EC1313] transition-colors line-clamp-2\">CẦU LÔNG – GIẢI TỎA NĂNG LƯỢNG</h3><p class=\"text-white/70 text-xs lg:text-sm leading-relaxed line-clamp-2 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300\">Không chỉ hết mình trong công việc, các thành viên BYD còn cháy hết mình trên sân cầu lông!</p></div></button><button type=\"button\" class=\"group relative overflow-hidden rounded-2xl cursor-pointer aspect-[4/3]  text-left\" aria-label=\"Xem ảnh: VINH DANH TOP DOANH THU\"><img src=\"/images/vinh-danh-top1.webp\" alt=\"VINH DANH TOP DOANH THU\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300\"></div><div class=\"absolute inset-0 flex flex-col justify-end p-5 lg:p-6\"><div class=\"flex items-center gap-2 mb-2\"><span class=\"inline-block bg-[#EC1313] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider\">🏆 Vinh danh</span><span class=\"text-white/60 text-xs\">T10/2024</span></div><h3 class=\"text-white font-bold text-sm lg:text-base leading-snug mb-1 group-hover:text-[#EC1313] transition-colors line-clamp-2\">VINH DANH TOP DOANH THU</h3><p class=\"text-white/70 text-xs lg:text-sm leading-relaxed line-clamp-2 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300\">Lễ trao giải Everest – Top 1 doanh thu. BYD tôn vinh những cá nhân xuất sắc đã cống hiến hết mình.</p></div></button><button type=\"button\" class=\"group relative overflow-hidden rounded-2xl cursor-pointer aspect-[4/3]  text-left\" aria-label=\"Xem ảnh: HAPPY MEN&#x27;S DAY\"><img src=\"/images/ngay-nam-gioi.webp\" alt=\"HAPPY MEN&#x27;S DAY\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300\"></div><div class=\"absolute inset-0 flex flex-col justify-end p-5 lg:p-6\"><div class=\"flex items-center gap-2 mb-2\"><span class=\"inline-block bg-[#EC1313] text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider\">🎉 Sự kiện</span><span class=\"text-white/60 text-xs\">11/2024</span></div><h3 class=\"text-white font-bold text-sm lg:text-base leading-snug mb-1 group-hover:text-[#EC1313] transition-colors line-clamp-2\">HAPPY MEN&#x27;S DAY</h3><p class=\"text-white/70 text-xs lg:text-sm leading-relaxed line-clamp-2 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300\">BYD chúc mừng ngày nam giới – cảm ơn các anh em đã luôn đồng hành và cống hiến!</p></div></button></div></div></section><section class=\"py-20 lg:py-28 bg-[#0F172A] relative overflow-hidden\"><div class=\"absolute inset-0 bg-gradient-to-br from-[#EC1313]/10 to-transparent pointer-events-none\"></div><div class=\"absolute top-0 right-0 w-96 h-96 bg-[#EC1313]/5 rounded-full translate-x-1/3 -translate-y-1/3 blur-3xl pointer-events-none\"></div><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full mb-4 border border-white/10\"><span class=\"text-white/80 text-xs font-bold tracking-widest uppercase\">Tiếng nói từ đội ngũ</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-white mb-4 tracking-tight\">BYD QUA LỜI KỂ NHÂN VIÊN</h2><p class=\"text-slate-400 text-lg max-w-2xl mx-auto\">Lắng nghe chia sẻ thực tế từ những thành viên đang đồng hành cùng BYD.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\"><div class=\"group bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 hover:-translate-y-1\"><svg class=\"w-10 h-10 text-[#EC1313]/40 mb-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z\"></path></svg><p class=\"text-white/80 leading-relaxed mb-6 italic\">“<!-- -->BYD không chỉ là nơi làm việc — mà là nơi tôi dám mơ lớn và biến ước mơ thành hiện thực. Tinh thần WOW ở đây thực sự truyền cảm hứng cho tôi mỗi ngày.<!-- -->”</p><div class=\"flex items-center gap-4\"><div class=\"w-12 h-12 rounded-full bg-[#EC1313] flex items-center justify-center text-white font-bold text-sm\">MA</div><div><div class=\"text-white font-semibold\">Nguyễn Minh Anh</div><div class=\"text-slate-400 text-sm\">Senior Developer, 3 năm tại BYD</div></div></div></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 hover:-translate-y-1\"><svg class=\"w-10 h-10 text-[#EC1313]/40 mb-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z\"></path></svg><p class=\"text-white/80 leading-relaxed mb-6 italic\">“<!-- -->Văn hóa 8 giá trị cốt lõi tại BYD không chỉ trên giấy — chúng tôi sống với nó mỗi ngày. Sự Tử Tế và Đoàn Kết là điều khen thưởng xứng đáng.<!-- -->”</p><div class=\"flex items-center gap-4\"><div class=\"w-12 h-12 rounded-full bg-[#EC1313] flex items-center justify-center text-white font-bold text-sm\">TH</div><div><div class=\"text-white font-semibold\">Trần Thị Hương</div><div class=\"text-slate-400 text-sm\">Marketing Manager, 4 năm tại BYD</div></div></div></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 hover:-translate-y-1\"><svg class=\"w-10 h-10 text-[#EC1313]/40 mb-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z\"></path></svg><p class=\"text-white/80 leading-relaxed mb-6 italic\">“<!-- -->BYD là nơi mỗi cá nhân đều có cơ hội tỏa sáng. Lộ trình từ Học việc đến Core Leader rất rõ ràng. Đó là điều tôi trân quý nhất.<!-- -->”</p><div class=\"flex items-center gap-4\"><div class=\"w-12 h-12 rounded-full bg-[#EC1313] flex items-center justify-center text-white font-bold text-sm\">VD</div><div><div class=\"text-white font-semibold\">Lê Văn Đức</div><div class=\"text-slate-400 text-sm\">Product Owner, 2 năm tại BYD</div></div></div></div></div></div></section><section class=\"py-20 bg-[#FAFAFA]\"><div class=\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"relative bg-gradient-to-br from-[#EC1313] to-[#b91010] rounded-3xl p-12 lg:p-16 text-white shadow-2xl shadow-red-200/50 overflow-hidden\"><div class=\"absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/3 translate-x-1/3\"></div><div class=\"absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/3 -translate-x-1/4\"></div><div class=\"relative text-center\"><h2 class=\"text-4xl lg:text-5xl font-black mb-5\">Bạn muốn trở thành một phần của BYD?</h2><p class=\"text-red-100 text-lg mb-10 max-w-2xl mx-auto leading-relaxed\">Khám phá cơ hội nghề nghiệp và cùng chúng tôi xây dựng tương lai thương mại điện tử Việt Nam.</p><div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\"><a class=\"bg-white text-[#EC1313] px-8 py-4 rounded-xl font-bold text-lg hover:bg-red-50 transition-colors w-full sm:w-auto shadow-lg text-center\" href=\"/tuyen-dung\">Xem vị trí tuyển dụng</a><a class=\"border-2 border-white/50 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/10 hover:border-white transition-all w-full sm:w-auto text-center\" href=\"/tuyen-dung/ung-tuyen\">Nộp hồ sơ ngay</a></div></div></div></div></section></div><!--$--><!--/$--></main><footer class=\"bg-[#0F172A] text-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10\"><div class=\"lg:col-span-1\"><img src=\"/images/byd-logo.png\" alt=\"BYD\" class=\"h-12 w-auto mb-5 rounded-lg\" width=\"160\" height=\"48\"/><p class=\"text-slate-300 text-sm leading-relaxed mb-4\">Công ty TNHH BYD Việt Nam</p><div class=\"space-y-2 text-sm text-slate-300\"><p><strong class=\"text-slate-300\">Email:</strong> hcns.byd@gmail.com</p><p><strong class=\"text-slate-300\">Hotline:</strong> 0969 240 885</p></div><div class=\"flex items-center gap-3 mt-5\"><a href=\"https://www.facebook.com/profile.php?id=61557780033666\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebook BYD\" class=\"w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center hover:bg-[#EC1313] transition-colors duration-300\"><svg class=\"w-4 h-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v