{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/(frontend)/layout,_N_T_/(frontend)/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/!KGZyb250ZW5kKQ/__PAGE__","/!KGZyb250ZW5kKQ","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"vi\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/images/byd-logo.png\" as=\"image\"/><link rel=\"preload\" href=\"/images/hero_banner.webp\" as=\"image\" fetchPriority=\"high\"/><link rel=\"stylesheet\" href=\"/_next/static/css/09844bcc633d00b4.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-09d2e605a48d46b3.js\"/><script src=\"/_next/static/chunks/4bd1b696-e356ca5ba0218e27.js\" async=\"\"></script><script src=\"/_next/static/chunks/3794-3fb4e6ee851037bb.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-3f2f4db84a984ed8.js\" async=\"\"></script><script src=\"/_next/static/chunks/8500-f62a38ff68ab7f42.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(frontend)/layout-9ab678a6f57c31ca.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/(frontend)/page-565c14a641d599b4.js\" async=\"\"></script><title>BYD Việt Nam - Build Your Dream</title><meta name=\"description\" content=\"Kiến tạo tương lai thương mại điện tử đột phá. Công ty TNHH BYD Việt Nam.\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex flex-col bg-white\"><div class=\"bg-[#EC1313] text-white text-xs hidden md:block relative z-50\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-9\"><div class=\"flex items-center gap-6\"><a href=\"mailto:hcns.byd@gmail.com\" class=\"flex items-center gap-1.5 hover:text-red-100 transi