n-colors\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path></svg></button><button type=\"button\" class=\"bg-[#EC1313] text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-[#d41111] transition-all hover:shadow-lg hover:shadow-red-200 duration-300\">Ứng tuyển ngay</button></div><button type=\"button\" aria-label=\"Mở menu điều hướng\" aria-expanded=\"false\" aria-controls=\"mobile-navigation\" class=\"md:hidden p-2 rounded-lg text-[#475569] hover:bg-slate-100\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></div></header><main class=\"flex-1\"><div class=\"bg-white\"><section class=\"relative min-h-[600px] lg:min-h-[700px] flex items-center overflow-hidden\"><div class=\"absolute inset-0\"><img src=\"/images/hero_banner.webp\" alt=\"BYD Hero\" class=\"w-full h-full object-cover\" loading=\"eager\" fetchPriority=\"high\" decoding=\"async\" width=\"1920\" height=\"1080\"/><div class=\"absolute inset-0 bg-gradient-to-r from-[#0F172A]/90 via-[#0F172A]/70 to-[#0F172A]/30\"></div></div><div class=\"absolute top-20 right-20 w-72 h-72 bg-[#EC1313]/10 rounded-full blur-3xl pointer-events-none\"></div><div class=\"absolute bottom-10 left-10 w-56 h-56 bg-[#EC1313]/5 rounded-full blur-2xl pointer-events-none\"></div><div class=\"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full\"><div class=\"max-w-2xl\"><div class=\"inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-5 py-2.5 rounded-full mb-8 border border-white/20\"><div class=\"w-2.5 h-2.5 rounded-full bg-[#EC1313] animate-pulse\"></div><span class=\"text-white/90 text-sm font-semibold tracking-wider uppercase\">Hệ sinh thái TMĐT đa ngành</span></div><h1 class=\"text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[1.05] mb-4 tracking-tight\">BYD - <span class=\"text-[#EC1313]\">Build Your</span><br/><span class=\"text-[#EC1313]\">Dream</span></h1><p class=\"text-xl lg:text-2xl text-white font-semibold mb-4 max-w-xl\">Thương mại điện tử &amp; phân phối sản phẩm đa nền tảng</p><p class=\"text-base lg:text-lg text-white/85 leading-relaxed mb-10 max-w-xl\">Hoạt động trong lĩnh vực Thương mại điện tử và Truyền thông đa nền tảng.</p><div class=\"flex flex-wrap gap-4\"><a class=\"group bg-[#EC1313] text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-[#d41111] transition-all duration-300 hover:shadow-2xl hover:shadow-red-500/30 flex items-center gap-3 cursor-pointer\" href=\"/linh-vuc\">Khám phá ngay<svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg></a><a class=\"border-2 border-white/40 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/10 hover:border-white/60 transition-all duration-300 backdrop-blur-sm cursor-pointer\" href=\"/gioi-thieu\">Tìm hiểu thêm</a></div></div></div><div class=\"absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-white to-transparent\"></div></section><section class=\"py-20 lg:py-28 bg-[#FAFAFA]\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center\"><div class=\"relative\"><div class=\"rounded-2xl overflow-hidden shadow-2xl\"><img src=\"/images/du-lich-cua-lo.webp\" alt=\"Đội ngũ BYD\" class=\"w-full h-auto object-cover\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"800\"/></div></div><div><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-6\"><div class=\"w-1.5 h-1.5 rounded-full bg-[#EC1313]\"></div><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Về BYD Việt Nam</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-6 leading-tight tracking-tight uppercase\">Kiến tạo hệ sinh thái thương mại điện tử đa ngành</h2><p class=\"text-[#475569] text-lg leading-relaxed mb-8\">BYD là doanh nghiệp hoạt động trong lĩnh vực thương mại điện tử đa nền tảng, đa quốc gia, tập trung phát triển mạnh tại thị trường Việt Nam &amp; Đông Nam Á. Công ty kinh doanh đa dạng ngành hàng: nông nghiệp, gia dụng, thời trang, mỹ phẩm và các sản phẩm thương hiệu, mang đến trải nghiệm mua sắm hiện đại - tiện lợi - đáng tin cậy cho khách hàng.</p><a class=\"group inline-flex items-center gap-3 bg-[#EC1313] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#d41111] transition-all duration-300 hover:shadow-lg hover:shadow-red-200 cursor-pointer\" href=\"/gioi-thieu\">Xem thêm<svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg></a></div></div></div></section><section class=\"py-20 lg:py-28 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Dịch vụ nổi bật</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-widest uppercase\">Lĩnh vực &amp; Dịch vụ</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">Chúng tôi cung cấp các giải pháp toàn diện cho chuỗi giá trị thương mại điện tử hiện đại.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500\" href=\"/linh-vuc\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/service_agriculture.webp\" alt=\"Nông nghiệp\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/></div><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Nông nghiệp</h3><p class=\"text-white/85 text-sm leading-relaxed line-clamp-2\">Sản phẩm tốt lành từ thiên nhiên, góp phần cải thiện sức khỏe và nâng cao chất lượng cuộc sống.</p><div class=\"mt-3 h-0.5 bg-[#EC1313] w-0 group-hover:w-full transition-all duration-500\"></div></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500\" href=\"/linh-vuc\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/service_homelife.webp\" alt=\"Gia dụng &amp; Đời sống\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/></div><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Gia dụng &amp; Đời sống</h3><p class=\"text-white/85 text-sm leading-relaxed line-clamp-2\">Sản phẩm gia dụng chất lượng cao, mang đến tiện nghi và sự thoải mái cho mỗi gia đình.</p><div class=\"mt-3 h-0.5 bg-[#EC1313] w-0 group-hover:w-full transition-all duration-500\"></div></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500\" href=\"/linh-vuc\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/service_fashion.webp\" alt=\"Thời trang\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/></div><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Thời trang</h3><p class=\"text-white/85 text-sm leading-relaxed line-clamp-2\">Phong cách và xu hướng - cập nhật liên tục các bộ sưu tập thời trang đa dạng.</p><div class=\"mt-3 h-0.5 bg-[#EC1313] w-0 group-hover:w-full transition-all duration-500\"></div></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500\" href=\"/linh-vuc\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/service_brand.webp\" alt=\"Hàng thương hiệu\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/></div><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Hàng thương hiệu</h3><p class=\"text-white/85 text-sm leading-relaxed line-clamp-2\">Sản phẩm chính hãng, uy tín từ các thương hiệu được yêu thích trong nước và quốc tế.</p><div class=\"mt-3 h-0.5 bg-[#EC1313] w-0 group-hover:w-full transition-all duration-500\"></div></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500\" href=\"/linh-vuc\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/service_beauty.webp\" alt=\"Mỹ phẩm &amp; Làm đẹp\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/></div><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Mỹ phẩm &amp; Làm đẹp</h3><p class=\"text-white/85 text-sm leading-relaxed line-clamp-2\">Sản phẩm chăm sóc sắc đẹp an toàn, giúp khách hàng sống khỏe hơn, đẹp hơn mỗi ngày.</p><div class=\"mt-3 h-0.5 bg-[#EC1313] w-0 group-hover:w-full transition-all duration-500\"></div></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500\" href=\"/linh-vuc\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/service_marketing.webp\" alt=\"Truyền thông thương mại\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/></div><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Truyền thông thương mại</h3><p class=\"text-white/85 text-sm leading-relaxed line-clamp-2\">Marketing đa nền tảng, tiếp cận khách hàng mục tiêu hiệu quả với chi phí tối ưu.</p><div class=\"mt-3 h-0.5 bg-[#EC1313] w-0 group-hover:w-full transition-all duration-500\"></div></div></a></div><div class=\"text-center mt-12\"><a class=\"group inline-flex items-center gap-3 border-2 border-[#EC1313] text-[#EC1313] px-8 py-4 rounded-xl font-bold hover:bg-[#EC1313] hover:text-white transition-all duration-300 cursor-pointer\" href=\"/linh-vuc\">Xem tất cả dịch vụ<svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg></a></div></div></section><section class=\"py-20 bg-[#FAFAFA] relative overflow-hidden\"><div class=\"absolute top-0 left-0 w-80 h-80 bg-[#EC1313]/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl\"></div><div class=\"absolute bottom-0 right-0 w-96 h-96 bg-[#EC1313]/5 rounded-full translate-x-1/3 translate-y-1/3 blur-3xl\"></div><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative\"><div class=\"text-center mb-16\"><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-widest uppercase\">Vì sao chọn BYD?</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">Được hàng triệu khách hàng và hàng trăm đối tác tin tưởng lựa chọn</p></div><div class=\"grid grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"text-center group\"><div class=\"w-20 h-20 mx-auto mb-5 rounded-2xl bg-white shadow-lg flex items-center justify-center group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300 border border-slate-100\"><svg class=\"w-10 h-10 text-[#EC1313]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z\"></path></svg></div><div class=\"text-4xl lg:text-5xl font-black text-[#EC1313] mb-2\">1000+</div><div class=\"text-[#475569] font-semibold text-sm uppercase tracking-wider\">Sản phẩm</div></div><div class=\"text-center group\"><div class=\"w-20 h-20 mx-auto mb-5 rounded-2xl bg-white shadow-lg flex items-center justify-center group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300 border border-slate-100\"><svg class=\"w-10 h-10 text-[#EC1313]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.591M6 10.5H3.75m4.007-4.243l-1.59-1.59\"></path></svg></div><div class=\"text-4xl lg:text-5xl font-black text-[#EC1313] mb-2\">50+</div><div class=\"text-[#475569] font-semibold text-sm uppercase tracking-wider\">Đối tác thương hiệu</div></div><div class=\"text-center group\"><div class=\"w-20 h-20 mx-auto mb-5 rounded-2xl bg-white shadow-lg flex items-center justify-center group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300 border border-slate-100\"><svg class=\"w-10 h-10 text-[#EC1313]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0116.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-3.77 1.522m0 0a6.003 6.003 0 01-3.77-1.522\"></path></svg></div><div class=\"text-4xl lg:text-5xl font-black text-[#EC1313] mb-2\">5+</div><div class=\"text-[#475569] font-semibold text-sm uppercase tracking-wider\">Ngành hàng</div></div><div class=\"text-center group\"><div class=\"w-20 h-20 mx-auto mb-5 rounded-2xl bg-white shadow-lg flex items-center justify-center group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300 border border-slate-100\"><svg class=\"w-10 h-10 text-[#EC1313]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z\"></path></svg></div><div class=\"text-4xl lg:text-5xl font-black text-[#EC1313] mb-2\">99%</div><div class=\"text-[#475569] font-semibold text-sm uppercase tracking-wider\">Khách hàng hài lòng</div></div></div></div></section><section class=\"py-20 lg:py-28 bg-[#0F172A] relative overflow-hidden\"><div class=\"absolute inset-0 bg-gradient-to-br from-[#EC1313]/10 to-transparent pointer-events-none\"></div><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative\"><div class=\"text-center mb-16\"><h2 class=\"text-3xl lg:text-4xl font-black text-white mb-4 tracking-widest uppercase\">Giá trị cốt lõi</h2><p class=\"text-slate-300 text-lg max-w-2xl mx-auto\">Những nguyên tắc nền tảng dẫn dắt mọi hoạt động của chúng tôi</p></div><div class=\"max-w-4xl mx-auto mb-12\"><div class=\"group bg-white/5 backdrop-blur-sm rounded-2xl p-12 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 text-center\"><div class=\"flex justify-center mb-8\"><div class=\"w-16 h-16 rounded-2xl bg-[#EC1313] flex items-center justify-center text-white\"><svg class=\"w-8 h-8\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z\"></path></svg></div></div><p class=\"text-white text-xl lg:text-2xl font-bold leading-relaxed uppercase tracking-wide\">Xây dựng BYD thành doanh nghiệp toàn cầu, phân phối sản phẩm Việt ra quốc tế, góp phần nâng cao vị thế kinh tế Việt Nam</p></div></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\"><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">01</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">NGHĨ LỚN</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Dám mơ những giấc mơ vĩ đại - bộ não sẽ tự tìm đường dẫn đến đích.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">02</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">TỐC ĐỘ</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Ai nhanh hơn, người đó chiến thắng - thực thi nhanh, học nhanh, thích nghi nhanh.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">03</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">ĐOÀN KẾT</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Yêu thương, thấu hiểu và bảo vệ nhau - sức mạnh tập thể vượt trội hơn nỗ lực cá nhân.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">04</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">HẠNH PHÚC</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Hạnh phúc đến từ lòng Biết Ơn - mỗi ngày tìm ít nhất một điều để biết ơn.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">05</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">TỬ TẾ</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Win-Win-Win: khách hàng, đối tác và BYD cùng thắng - đó mới là giá trị bền vững.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">06</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">KỶ LUẬT</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Kỷ luật đưa chúng ta tới nơi mà động lực không thể - nền tảng của mọi thành công.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">07</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">CHUYÊN GIA</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Không ngừng trau dồi kiến thức và kỹ năng - trở thành chuyên gia trong lĩnh vực của mình để tạo ra giá trị vượt trội.</p></div><div class=\"group bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/10 hover:border-[#EC1313]/30 transition-all duration-300 cursor-default\"><div class=\"w-10 h-10 rounded-full bg-[#EC1313] text-white flex items-center justify-center text-sm font-bold mb-4\">08</div><h3 class=\"text-base font-bold text-white mb-2 tracking-wide\">SÁNG TẠO</h3><p class=\"text-slate-300 text-sm leading-relaxed\">Luôn tìm kiếm cách làm mới, đột phá - biến ý tưởng thành hành động tạo nên sự khác biệt.</p></div></div></div></section><section class=\"py-20 lg:py-28 bg-[#FAFAFA]\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><div class=\"w-1.5 h-1.5 rounded-full bg-[#EC1313]\"></div><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Cuộc sống tại BYD</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-widest uppercase\">Đội ngũ &amp; Văn hóa</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">BYD không chỉ là nơi làm việc - đó là gia đình thứ hai, nơi mỗi người đều được tỏa sáng</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 aspect-[16/10]\" href=\"/van-hoa\"><img src=\"/images/du-lich-cua-lo.webp\" alt=\"Trải nghiệm &amp; Gắn kết\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"750\"/><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/80 via-[#0F172A]/20 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Trải nghiệm &amp; Gắn kết</h3><p class=\"text-white/85 text-sm\">Cùng nhau tạo kỷ niệm - vì đội ngũ mạnh bắt đầu từ sự kết nối</p></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 aspect-[16/10]\" href=\"/van-hoa\"><img src=\"/images/trao-thuong-byd.webp\" alt=\"Ghi nhận &amp; Tôn vinh\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"750\"/><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/80 via-[#0F172A]/20 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Ghi nhận &amp; Tôn vinh</h3><p class=\"text-white/85 text-sm\">Mỗi nỗ lực đều xứng đáng được công nhận và tưởng thưởng</p></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 aspect-[16/10]\" href=\"/van-hoa\"><img src=\"/images/sinh-nhat-quy4.webp\" alt=\"Ấm áp như gia đình\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"750\"/><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/80 via-[#0F172A]/20 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Ấm áp như gia đình</h3><p class=\"text-white/85 text-sm\">BYD là gia đình thứ hai - nơi bạn được quan tâm mỗi ngày</p></div></a><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 aspect-[16/10]\" href=\"/van-hoa\"><img src=\"/images/hoat-dong-20-10.webp\" alt=\"Yêu thương &amp; Sẻ chia\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"750\"/><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/80 via-[#0F172A]/20 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-6\"><h3 class=\"text-white font-bold text-lg mb-1 uppercase group-hover:text-[#EC1313] transition-colors\">Yêu thương &amp; Sẻ chia</h3><p class=\"text-white/85 text-sm\">Những khoảnh khắc đặc biệt dành cho những con người đặc biệt</p></div></a></div><div class=\"text-center mt-12\"><a class=\"group inline-flex items-center gap-3 border-2 border-[#EC1313] text-[#EC1313] px-8 py-4 rounded-xl font-bold hover:bg-[#EC1313] hover:text-white transition-all duration-300 cursor-pointer\" href=\"/van-hoa\">Khám phá văn hóa BYD<svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg></a></div></div></section><section class=\"py-20 lg:py-28 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex items-end justify-between mb-14\"><div><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Tin tức mới nhất</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] tracking-tight\">Tin tức &amp; Hoạt động</h2></div><a class=\"hidden md:flex items-center gap-2 text-[#EC1313] font-bold hover:gap-3 transition-all text-sm cursor-pointer\" href=\"/tin-tuc\">Xem tất cả<svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path></svg></a></div><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6\"><a class=\"group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500 min-h-[400px] lg:min-h-[500px]\" aria-label=\"Xem bài viết Happy Birthday - Nhân sự Quý I của BYD\" href=\"/tin-tuc\"><img src=\"/images/sinh-nhat-quy4.webp\" alt=\"Happy Birthday - Nhân sự Quý I của BYD\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 absolute inset-0\" loading=\"lazy\" decoding=\"async\" width=\"1200\" height=\"900\"/><div class=\"absolute inset-0 bg-gradient-to-t from-[#0F172A]/90 via-[#0F172A]/30 to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-8\"><span class=\"inline-block bg-[#EC1313] text-white text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider mb-4\">Văn hóa</span><h3 class=\"text-2xl font-bold text-white mb-3 leading-tight group-hover:text-[#EC1313] transition-colors\">Happy Birthday - Nhân sự Quý I của BYD</h3><p class=\"text-white/85 leading-relaxed mb-3 line-clamp-2\">Công ty trân trọng gửi lời chúc mừng sinh nhật tới các thành viên có ngày sinh trong tháng 1, 2 và 3.</p><span class=\"text-white/70 text-sm\">31 Tháng 3, 2025</span></div></a><div class=\"flex flex-col gap-6\"><a class=\"group flex gap-5 bg-[#FAFAFA] rounded-2xl overflow-hidden cursor-pointer hover:shadow-lg transition-all duration-300 border border-slate-100\" aria-label=\"Xem bài viết 8/3 - Ngày của hội chị em BYD\" href=\"/tin-tuc\"><div class=\"w-48 lg:w-56 shrink-0 overflow-hidden\"><img src=\"/images/hoat-dong-20-10.webp\" alt=\"8/3 - Ngày của hội chị em BYD\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" loading=\"lazy\" decoding=\"async\" width=\"672\" height=\"448\"/></div><div class=\"flex flex-col justify-center py-5 pr-5\"><span class=\"text-[#EC1313] text-xs font-bold uppercase tracking-wider mb-2\">Sự kiện</span><h3 class=\"font-bold text-[#0F172A] mb-2 leading-snug line-clamp-2 group-hover:text-[#EC1313] transition-colors\">8/3 - Ngày của hội chị em BYD</h3><p class=\"text-[#64748B] text-sm leading-relaxed mb-3 line-clamp-2\">Nhân ngày Quốc tế Phụ nữ 8/3, BYD gửi lời chúc toàn thể chị em luôn xinh đẹp, ví luôn đầy và mood luôn chill!</p><span class=\"text-[#64748B] text-xs\">8 Tháng 3, 2025</span></div></a><a class=\"group flex gap-5 bg-[#FAFAFA] rounded-2xl overflow-hidden cursor-pointer hover:shadow-lg transition-all duration-300 border border-slate-100\" aria-label=\"Xem bài viết Team Building Cửa Lò 2025 - Kết nối đội ngũ\" href=\"/tin-tuc\"><div class=\"w-48 lg:w-56 shrink-0 overflow-hidden\"><img src=\"/images/du-lich-cua-lo.webp\" alt=\"Team Building Cửa Lò 2025 - Kết nối đội ngũ\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" loading=\"lazy\" decoding=\"async\" width=\"672\" height=\"448\"/></div><div class=\"flex flex-col justify-center py-5 pr-5\"><span class=\"text-[#EC1313] text-xs font-bold uppercase tracking-wider mb-2\">Sự kiện</span><h3 class=\"font-bold text-[#0F172A] mb-2 leading-snug line-clamp-2 group-hover:text-[#EC1313] transition-colors\">Team Building Cửa Lò 2025 - Kết nối đội ngũ</h3><p class=\"text-[#64748B] text-sm leading-relaxed mb-3 line-clamp-2\">Chuyến du lịch gắn kết đội ngũ tại Cửa Lò, nơi anh em cùng nhau tận hưởng những khoảnh khắc đáng nhớ.</p><span class=\"text-[#64748B] text-xs\">20 Tháng 1, 2025</span></div></a></div></div></div></section><section class=\"py-20 lg:py-28 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-14\"><div class=\"inline-flex items-center gap-2 bg-[rgba(236,19,19,0.08)] px-4 py-2 rounded-full mb-4\"><span class=\"text-[#EC1313] text-xs font-bold tracking-widest uppercase\">Liên hệ</span></div><h2 class=\"text-3xl lg:text-4xl font-black text-[#0F172A] mb-4 tracking-widest uppercase\">Vị trí của chúng tôi</h2><p class=\"text-[#64748B] text-lg max-w-2xl mx-auto\">Ghé thăm văn phòng BYD để được tư vấn trực tiếp</p></div><div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8\"><div class=\"lg:col-span-2 rounded-2xl overflow-hidden shadow-lg border border-slate-100 min-h-[400px]\"><iframe title=\"BYD Vietnam Office Location\" src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3725.292576914698!2d105.83138!3d20.98234!2m3!1f0!2f0!3f0!2m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ac5b0e66c95d%3A0x1e4bcf42e2f5e0e4!2zTmd1eeG7hW4gWGnhu4NuLCDEkOG7i25oIEPDtG5nLCBIb8OgbmcgTWFpLCBIw6AgTuG7mWk!5e0!3m2!1svi!2s!4v1709900000000\" width=\"100%\" height=\"100%\" style=\"border:0;min-height:400px\" allowFullScreen=\"\" loading=\"lazy\" referrerPolicy=\"no-referrer-when-downgrade\"></iframe></div><div class=\"flex flex-col gap-5\"><div class=\"group bg-[#FAFAFA] rounded-2xl p-6 border border-slate-100 hover:shadow-lg hover:border-[#EC1313]/20 transition-all duration-300\"><div class=\"w-12 h-12 rounded-xl bg-[#EC1313]/10 flex items-center justify-center mb-4 group-hover:bg-[#EC1313] transition-colors duration-300\"><svg class=\"w-6 h-6 text-[#EC1313] group-hover:text-white transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\"></path><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\"></path></svg></div><h3 class=\"font-bold text-[#0F172A] mb-2\">Trụ sở chính</h3><p class=\"text-[#475569] text-sm leading-relaxed\">Số 12, Sunrise K, Đại lộ 10 (10th Ave),<br/>Ktral Park, đường Nguyễn Xiển,<br/>Phường Định Công, TP. Hà Nội</p></div><a href=\"tel:+84969240885\" class=\"group bg-[#FAFAFA] rounded-2xl p-6 border border-slate-100 hover:shadow-lg hover:border-[#EC1313]/20 transition-all duration-300 block cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-[#EC1313]/10 flex items-center justify-center mb-4 group-hover:bg-[#EC1313] transition-colors duration-300\"><svg class=\"w-6 h-6 text-[#E